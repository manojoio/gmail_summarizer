        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{\n        JSON.stringify(\n          \"Analyze the following email.\\n\\n\" +\n          \"Sender: \" + $json.Sender + \"\\n\\n\" +\n          \"Subject: \" + $json.Subject + \"\\n\\n\" +\n          \"Body:\\n\" + $json.Body + \"\\n\\n\" +\n          \"Return ONLY valid JSON. Do not include explanations, markdown, or code fences.\\n\\n\" +\n          \"Format:\\n\" +\n          \"{\\n\" +\n          \"  \\\"summary\\\": \\\"\\\",\\n\" +\n          \"  \\\"category\\\": \\\"\\\",\\n\" +\n          \"  \\\"priority\\\": \\\"\\\",\\n\" +\n          \"  \\\"action_required\\\": \\\"\\\",\\n\" +\n          \"  \\\"action_items\\\": \\\"\\\"\\n\" +\n          \"}\\n\\n\" +\n          \"Category must be one of: Work, Finance, Marketing, Personal, Newsletter, Notification, Other.\\n\" +\n          \"Priority must be one of: High, Medium, Low.\"\n        )\n      }}\n    }\n  ]\n}",
        "options": {}

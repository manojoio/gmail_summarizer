    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n\n  const html = item.json.html || \"\";\n\n  const text = html\n    .replace(/<style[\\s\\S]*?<\\/style>/gi, \"\")\n    .replace(/<script[\\s\\S]*?<\\/script>/gi, \"\")\n    .replace(/<[^>]+>/g, \" \")\n    .replace(/\\s+/g, \" \")\n    .trim();\n\n  item.json.extractedText = text;\n}\n\nreturn $input.all();"
      },
